 public Fish(int xV) {
        x = xV;
        y = 0;
        dy = 2;
        width = 55;
        height = 55;
double r = Math.random();
if (r < 0.15) {
    imageName = "Blackberry.png";
    pic = new ImageIcon("Blackberry.png");
} else if (r < 0.30) {
    imageName = "Cherry.png";
    pic = new ImageIcon("Cherry.png");
} else if (r < 0.45) {
    imageName = "Blueberry.png";
    pic = new ImageIcon("Blueberry.png");
} else if (r < 0.60) {
    imageName = "Strawberry.png";
    pic = new ImageIcon("Strawberry.png");
} else if (r < 0.75) {
    imageName = "Raspberry.png";
    pic = new ImageIcon("Raspberry.png");
} else {
    imageName = "Custard.png";             
    pic = new ImageIcon("Custard.png");   
}
 }
        


    
    public boolean collidesWith(Hook hook) {
    return this.x < hook.getX() + hook.getWidth() &&
           this.x + this.width > hook.getX() &&
           this.y < hook.getY() + hook.getHeight() &&
           this.y + this.height > hook.getY();
}
