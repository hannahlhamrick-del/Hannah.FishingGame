import javax.swing.ImageIcon;
import java.awt.Rectangle;

public class Fish {
    private int x, y, width, height, dx;
    private ImageIcon fish1;
    private ImageIcon fish2;


    public Fish() {
        x = -100; // start off-screen left
        y = (int)(Math.random() * 600);
        dx = 3;

        width = 80;
        height = 60;

        fish1 = new ImageIcon("Fishy2k.png"); 
        fish2 = new ImageIcon("Fish2y2k.png"); 
    }

    public void move() {
        x += dx;
    }

    public boolean collidesWith(Hook hook) {
        Rectangle r1 = new Rectangle(x, y, width, height);
        Rectangle r2 = new Rectangle(hook.getX(), hook.getY(), hook.getWidth(), hook.getHeight());
        return r1.intersects(r2);
    }

    public int getX() { return x; }
    public int getY() { return y; }
    public int getWidth() { return width; }
    public int getHeight() { return height; }
    public ImageIcon getFish1() { return fish1; }
    public ImageIcon getFish2() { return fish2; }
}
